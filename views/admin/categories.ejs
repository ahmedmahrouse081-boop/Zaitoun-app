<%- include('layout', { title: 'التصنيفات' }) %>
<div class="page-header">
  <h1>التصنيفات</h1>
  <a href="/admin/categories/new" class="btn btn-primary">+ إضافة تصنيف</a>
</div>
<table class="admin-table">
  <thead><tr><th>الاسم</th><th>الترتيب</th><th>الأصناف</th><th>إجراءات</th></tr></thead>
  <tbody>
    <% categories.forEach(function(cat) { %>
      <tr>
        <td><%= cat.name %></td>
        <td><%= cat.sort_order %></td>
        <td><%= cat.item_count %></td>
        <td class="actions">
          <a href="/admin/categories/<%= cat.id %>/edit" class="btn btn-sm">تعديل</a>
          <form action="/admin/categories/<%= cat.id %>/delete" method="POST" onsubmit="return confirm('هل أنت متأكد من حذف هذا التصنيف؟')" style="display:inline">
            <button type="submit" class="btn btn-sm btn-danger">حذف</button>
          </form>
        </td>
      </tr>
    <% }); %>
  </tbody>
</table>
<%- include('../partials/footer') %>
