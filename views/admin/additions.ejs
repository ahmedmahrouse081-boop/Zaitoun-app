<%- include('layout', { title: 'الإضافات' }) %>
<div class="page-header">
  <h1>الإضافات</h1>
  <a href="/admin/additions/new" class="btn btn-primary">+ إضافة إضافة</a>
</div>
<table class="admin-table">
  <thead><tr><th>الاسم</th><th>السعر</th><th>متاح</th><th>يستخدم في</th><th>إجراءات</th></tr></thead>
  <tbody>
    <% additions.forEach(function(add) { %>
      <tr>
        <td><%= add.name %></td>
        <td>ج.م<%= add.price.toFixed(2) %></td>
        <td><%= add.available ? 'نعم' : 'لا' %></td>
        <td><%= add.item_count %></td>
        <td class="actions">
          <a href="/admin/additions/<%= add.id %>/edit" class="btn btn-sm">تعديل</a>
          <form action="/admin/additions/<%= add.id %>/delete" method="POST" onsubmit="return confirm('هل أنت متأكد من حذف هذه الإضافة؟')" style="display:inline">
            <button type="submit" class="btn btn-sm btn-danger">حذف</button>
          </form>
        </td>
      </tr>
    <% }); %>
  </tbody>
</table>
<%- include('../partials/footer') %>
