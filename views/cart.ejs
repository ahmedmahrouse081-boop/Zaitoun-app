<%- include('partials/header', { title: 'السلة' }) %>
<div class="cart-page">
<div class="back-link"><a href="/">&larr; متابعة الطلب</a></div>
<h1>سلة المشتريات</h1>
<% if (locals.cart && cart.length > 0) { %>
  <div class="cart-list">
    <% cart.forEach(function(item) { %>
      <div class="cart-item">
        <div class="cart-item-info">
          <h3><%= item.itemName %></h3>
          <% if (item.additions.length > 0) { %>
            <p class="cart-additions">+ <%= item.additions.map(function(a) { return a.name; }).join(', ') %></p>
          <% } %>
          <p class="cart-price">ج.م<%= item.unitPrice.toFixed(2) %> للواحدة</p>
        </div>
        <div class="cart-item-actions">
          <form action="/cart/update" method="POST" class="qty-form">
            <input type="hidden" name="id" value="<%= item.id %>">
            <input type="number" name="quantity" value="<%= item.quantity %>" min="1" class="qty-input" onchange="this.form.submit()">
          </form>
          <p class="cart-total">ج.م<%= (item.unitPrice * item.quantity).toFixed(2) %></p>
          <form action="/cart/remove" method="POST">
            <input type="hidden" name="id" value="<%= item.id %>">
            <button type="submit" class="btn btn-danger btn-sm">إزالة</button>
          </form>
        </div>
      </div>
    <% }); %>
    <div class="cart-summary">
      <h3>الإجمالي: ج.م<%= cart.reduce(function(s, i) { return s + i.unitPrice * i.quantity; }, 0).toFixed(2) %></h3>
      <a href="/checkout" class="btn btn-primary">إتمام الطلب</a>
    </div>
  </div>
<% } else { %>
  <div class="empty-state">
    <p>سلة المشتريات فارغة.</p>
    <a href="/" class="btn btn-primary">تصفح القائمة</a>
  </div>
<% } %>
</div>
<%- include('partials/footer') %>
